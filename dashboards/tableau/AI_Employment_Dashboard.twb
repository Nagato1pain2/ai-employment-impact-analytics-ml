              <formatted-text>
                <run bold='true' fontcolor='#ffffff' fontsize='14'>Industry Perforfmance, Geographical Trends, and AI Adoption Insights</run>
              </formatted-text>
              <zone-style>
                <format attr='border-color' value='#000000' />
                <format attr='border-style' value='none' />
                <format attr='border-width' value='0' />
                <format attr='margin' value='0' />
